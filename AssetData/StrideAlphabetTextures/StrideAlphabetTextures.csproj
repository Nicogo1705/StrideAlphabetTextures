<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>StrideAlphabetTextures</RootNamespace>
    <AssemblyName>StrideAlphabetTextures</AssemblyName>
  </PropertyGroup>

  <!-- The Stride version is detected here, from the Stride.* PackageReference. -->
